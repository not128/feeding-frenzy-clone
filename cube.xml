<mujoco model="cube">
  <compiler angle="degree" coordinate="local"/>
  <option timestep="0.01"/>

  <worldbody>
    <!-- Ground plane -->
    <geom name="floor" type="plane" size="10 10 0.1" rgba="0.9 0.9 0.9 1"/>

    <!-- Cube body -->
    <body name="box" pos="0 0 1">
      <geom type="box" size="0.1 0.1 0.1" rgba="0.2 0.5 0.8 1"/>
      <joint type="free"/>
    </body>
  </worldbody>
</mujoco>
